# Propertybase / Web2Prospect integration.
# Copy to .env.local for local dev, and set these in Vercel Project Settings for
# production. All are OPTIONAL: with none set, the app runs in "dry-run" mode —
# the form validates and completes, but no data is sent to Propertybase.

# --- Lead submission (POST /api/lead -> Web2Prospect) ---
# The apexrest Web2Prospect endpoint for the org. Examples:
#   Prod:    https://<org>.my.salesforce-sites.com/services/apexrest/pba/webtoprospect/v1/
#   Sandbox: https://<org>--dev.sandbox.my.salesforce-sites.com/services/apexrest/pba/webtoprospect/v1/
PROPERTYBASE_W2P_BASE_URL=
# The Web2Prospect token. NOTE: a token was present in the old WordPress DB dump
# (w2p_settings) — rotate it before use; do not reuse the leaked value.
PROPERTYBASE_W2P_TOKEN=

# --- Referral prefill lookup (GET /api/prefill -> Salesforce REST) ---
# Used to resolve ?id=<Property a0E...> / ?contactId=<003...> to the visitor's
# details. Separate from the W2P token (Salesforce OAuth).
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=
